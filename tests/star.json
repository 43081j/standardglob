{
  "description": "The * wildcard: matches any run of characters within a single path segment (does not cross /).",
  "tests": [
    {
      "pattern": "src/*.ts",
      "cases": [
        { "input": "src/index.ts", "match": true },
        { "input": "src/a.ts", "match": true },
        { "input": "src/index.js", "match": false },
        { "input": "src/a/b.ts", "match": false },
        { "input": "index.ts", "match": false },
        { "input": "src/index.ts/x", "match": false }
      ]
    },
    {
      "pattern": "*",
      "cases": [
        { "input": "a", "match": true },
        { "input": "abc", "match": true },
        { "input": "a/b", "match": false }
      ]
    },
    {
      "pattern": "*.ts",
      "cases": [
        { "input": "a.ts", "match": true },
        { "input": "a.js", "match": false },
        { "input": "a/b.ts", "match": false }
      ]
    },
    {
      "pattern": "a*c",
      "cases": [
        { "input": "ac", "match": true },
        { "input": "abc", "match": true },
        { "input": "abbbc", "match": true },
        { "input": "abcd", "match": false },
        { "input": "xabc", "match": false }
      ]
    }
  ]
}
