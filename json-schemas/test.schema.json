{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"required": [
		"name",
		"tests"
	],
	"properties": {
		"name": {
			"type": "string",
			"minLength": 3
		},
		"tests": {
			"type": "array",
			"items": {
				"type": "object",
				"required": [
					"name",
					"pattern"
				],
				"properties": {
					"name": {
						"type": "string",
						"minLength": 3
					},
					"pattern": {
						"type": "string"
					},
					"matches": {
						"type": "array",
						"items": {
							"type": "string"
						}
					},
					"rejects": {
						"type": "array",
						"items": {
							"type": "string"
						}
					},
					"error": {
						"type": "string"
					}
				}
			}
		}
	}
}
